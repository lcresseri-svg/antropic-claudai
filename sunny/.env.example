# Configurazione Firebase — copia questo file in `.env.local` e riempi i valori.
# `.env.local` è gitignored: non verrà mai committato.
# La chiave API in produzione arriva dal GitHub Secret VITE_FIREBASE_API_KEY
# (vedi .github/workflows/deploy-firebase.yml).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=sunny-a2a98.web.app
VITE_FIREBASE_PROJECT_ID=sunny-a2a98
VITE_FIREBASE_STORAGE_BUCKET=sunny-a2a98.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=1059291331006
VITE_FIREBASE_APP_ID=1:1059291331006:web:f62698cd6f0c6da1caa1ef

# App Check (rollout non bloccante): lasciare vuoto per disattivarlo.
# Con la site key reCAPTCHA v3 il client allega il token; l'enforcement lato
# Functions è separato (variabile APPCHECK_ENFORCE=true nel deploy functions).
VITE_APPCHECK_SITE_KEY=
# Solo sviluppo locale: token di debug registrato nella console Firebase.
VITE_APPCHECK_DEBUG_TOKEN=
