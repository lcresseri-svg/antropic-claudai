rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function signedIn() { return request.auth != null; }
    function owner(userId) { return signedIn() && request.auth.uid == userId; }
    // Admin identity for privileged reads (feedback). Mirrors the app's admin UID.
    function isAdmin() { return signedIn() && request.auth.uid == 'qPtCOJGRrwOZ2EfjxMHwW6ZISXX2'; }

    function vStr(v, maxLen) { return v is string && v.size() <= maxLen; }
    // Positive amount with a generous TECHNICAL cap (anti-DoS only, not a product limit).
    function vAmount(v) { return v is number && v > 0 && v <= 1000000000; }
    function vDate(v) { return v is string && v.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$'); }

    // Behavioural metric event: EXACTLY { name, ts } with name in the allowlist.
    // No financial data ever. Mirrored in sunny/src/shared/analytics/metrics.ts
    // and the rollup Cloud Function — keep the three allowlists in sync.
    function validEvent(d) {
      return d.keys().hasOnly(['name', 'ts'])
        && d.ts is number
        && d.name in ['app_open', 'insights_view', 'insight_open', 'notif_open', 'tx_add', 'forecast_view', 'aicoach_open'];
    }

    // Non-breaking transaction validation. Validates only fields known to be
    // written by the client/import; intentionally does NOT use hasOnly() in this
    // phase, and does NOT constrain createdAt/updatedAt/projected so existing and
    // future client writes keep working.
    function validTxn(d) {
      return d.keys().hasAll(['date', 'description', 'amount', 'type', 'category', 'account'])
        && vDate(d.date)
        && vAmount(d.amount)
        && d.type in ['expense', 'income', 'investment', 'transfer']
        && vStr(d.description, 500)
        && vStr(d.category, 200)
        && d.account is string && d.account.size() <= 200          // '' valid for source-less investments
        && (!('notes' in d) || vStr(d.notes, 2000))
        && (!('shared' in d) || (d.shared is number && d.shared >= 0 && d.shared <= d.amount))
        && (!('direction' in d) || d.direction in ['in', 'out'])
        && (!('toAccount' in d) || vStr(d.toAccount, 200))
        && (!('tfr' in d) || (d.tfr is number && d.tfr >= 0 && d.tfr <= d.amount))
        // Statistical spread of a one-off investment deposit (2–120 months).
        && (!('statsSpreadMonths' in d) || (d.statsSpreadMonths is int && d.statsSpreadMonths >= 2 && d.statsSpreadMonths <= 120))
        // Future-dated investment whose controvalore effect is deferred to the
        // idempotent reconciler. Boolean marker, cleared once applied.
        && (!('valuePending' in d) || d.valuePending is bool)
        && (!('seriesId' in d) || vStr(d.seriesId, 128))
        && (!('groupId' in d) || vStr(d.groupId, 128))
        && (!('demo' in d) || d.demo is bool)
        // Controvalore sync (investments): optional explicit value delta and
        // the bookkeeping stamp of the delta actually applied. Bounded numbers
        // only — the same anti-DoS cap used for amount.
        && (!('valueDelta' in d) || (d.valueDelta is number && d.valueDelta >= -1000000000 && d.valueDelta <= 1000000000))
        && (!('valueEffect' in d) || (
              d.valueEffect is map
              && d.valueEffect.keys().hasOnly(['category', 'delta', 'appliedAt'])
              && vStr(d.valueEffect.category, 200)
              && d.valueEffect.delta is number
              && d.valueEffect.delta >= -1000000000 && d.valueEffect.delta <= 1000000000
              && d.valueEffect.appliedAt is number
           ))
        && (!('recurring' in d) || (
              d.recurring is map
              && d.recurring.freq in ['daily', 'weekly', 'monthly', 'yearly']
              && (!('until' in d.recurring) || vDate(d.recurring.until))
           ))
        // Smart-series metadata (subscription / installment). Input data only —
        // derived figures are computed client-side and never stored.
        && (!('seriesMeta' in d) || (
              d.seriesMeta is map
              && d.seriesMeta.kind in ['recurring', 'subscription', 'installment']
              && (!('createdAt' in d.seriesMeta) || d.seriesMeta.createdAt is number)
              && (!('subscription' in d.seriesMeta) || (
                    d.seriesMeta.subscription is map
                    && (!('label' in d.seriesMeta.subscription) || vStr(d.seriesMeta.subscription.label, 200))
                 ))
              && (!('installment' in d.seriesMeta) || (
                    d.seriesMeta.installment is map
                    && d.seriesMeta.installment.totalAmount is number
                    && d.seriesMeta.installment.totalAmount > 0
                    && d.seriesMeta.installment.totalInstallments is int
                    && d.seriesMeta.installment.totalInstallments > 0
                    && vDate(d.seriesMeta.installment.firstDate)
                 ))
           ));
    }

    // Each user can only read and write their own data.
    // The Admin SDK (Cloud Functions) bypasses these rules entirely.
    match /users/{userId} {
      allow read, write: if owner(userId);

      match /transactions/{txId} {
        allow read, delete: if owner(userId);
        // Create & update must keep the document well-formed (types, enums,
        // ranges, lengths). amount > 0 is preserved from the previous ruleset.
        allow create, update: if owner(userId) && validTxn(request.resource.data);
      }

      // ── meta/* — one rule per KNOWN document, with light non-breaking
      // validation (only fields that are present are checked, so legacy docs
      // keep working). Unknown doc names keep the historical owner-only
      // access until they too are enumerated (gradual hardening).
      match /meta/settings {
        allow read: if owner(userId);
        allow write: if owner(userId)
          && (!('categories' in request.resource.data) || (request.resource.data.categories is list && request.resource.data.categories.size() <= 500))
          && (!('accounts' in request.resource.data) || (request.resource.data.accounts is list && request.resource.data.accounts.size() <= 200))
          && (!('theme' in request.resource.data) || request.resource.data.theme in ['system', 'dark', 'light'])
          && (!('insightDepth' in request.resource.data) || request.resource.data.insightDepth in ['minimal', 'medium', 'advanced'])
          && (!('enableInvestments' in request.resource.data) || request.resource.data.enableInvestments is bool)
          && (!('enableBudget' in request.resource.data) || request.resource.data.enableBudget is bool)
          && (!('aiEnabled' in request.resource.data) || request.resource.data.aiEnabled is bool);
      }

      match /meta/budget {
        allow read: if owner(userId);
        allow write: if owner(userId)
          && (!('savingsTarget' in request.resource.data) || (request.resource.data.savingsTarget is number && request.resource.data.savingsTarget >= 0))
          && (!('categoryBudgets' in request.resource.data) || request.resource.data.categoryBudgets is map)
          && (!('incomeBudgets' in request.resource.data) || request.resource.data.incomeBudgets is map)
          && (!('investmentBudgets' in request.resource.data) || request.resource.data.investmentBudgets is map);
      }

      match /meta/push {
        allow read: if owner(userId);
        allow write: if owner(userId)
          && (!('tokens' in request.resource.data) || request.resource.data.tokens is map)
          && (!('reminders' in request.resource.data) || request.resource.data.reminders is map);
      }

      match /meta/onboarding {
        allow read: if owner(userId);
        allow write: if owner(userId)
          && (!('completed' in request.resource.data) || request.resource.data.completed is bool)
          && (!('currentStep' in request.resource.data) || request.resource.data.currentStep is number);
      }

      match /meta/activity {
        allow read: if owner(userId);
        allow write: if owner(userId)
          && (!('lastActiveAt' in request.resource.data) || request.resource.data.lastActiveAt is number)
          && (!('activeDays' in request.resource.data) || (request.resource.data.activeDays is list && request.resource.data.activeDays.size() <= 60));
      }

      // AI rate-limit state is managed by Cloud Functions (Admin SDK); the
      // client may read its remaining quota but never write it.
      match /meta/aiCoach {
        allow read: if owner(userId);
        allow write: if false;
      }

      // Legacy fallback for meta docs not yet enumerated above. Kept for
      // backward compatibility; shrink over time as docs get specific rules.
      match /meta/{doc} {
        allow read, write: if owner(userId)
          && !(doc in ['settings', 'budget', 'push', 'onboarding', 'activity', 'aiCoach']);
      }

      // Monthly budget snapshots (doc id = YYYY-MM). Owner-only; light non-breaking
      // validation (numbers >= 0, known enums). The client always writes the full
      // MonthlyBudget object, so these fields are always present.
      match /budgetHistory/{month} {
        allow read: if owner(userId);
        allow write: if owner(userId)
          && request.resource.data.savingsTarget is number
          && request.resource.data.savingsTarget >= 0
          && request.resource.data.categoryBudgets is map
          && request.resource.data.status in ['draft', 'confirmed', 'missing', 'auto_initialized']
          && request.resource.data.source in ['manual', 'copied_from_previous_month', 'copied_from_legacy_budget', 'auto_initialized'];
      }

      // Forecast backtest snapshots: immutable audit trail written by the V3 engine.
      // Write-once: only create is allowed — update and delete are intentionally
      // denied. (Verified: the client only ever creates non-existent snapshots.)
      // Payload validation: the core identifying/metric fields must be typed.
      match /forecastSnapshots/{snapshotId} {
        allow read: if owner(userId);
        allow create: if owner(userId)
          && request.resource.data.monthKey is string
          && request.resource.data.monthKey.matches('^[0-9]{4}-[0-9]{2}$')
          && request.resource.data.snapshotDay is int
          && request.resource.data.snapshotDay >= 1
          && request.resource.data.snapshotDay <= 31
          && request.resource.data.actual is number
          && request.resource.data.predicted is number;
      }

      // Daily wealth snapshots (doc id = YYYY-MM-DD, Europe/Rome). Owner-only.
      // Create AND update are allowed with the same validation — regeneration
      // is idempotent (same day → same doc, overwritten in place). Deletes are
      // denied to clients: snapshots are an audit trail.
      match /wealthSnapshots/{day} {
        allow read: if owner(userId);
        allow create, update: if owner(userId)
          && day.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
          && request.resource.data.dateKey == day
          && request.resource.data.version is int
          && request.resource.data.version >= 1
          && request.resource.data.totalNetWorth is number
          && request.resource.data.cash is number
          && request.resource.data.investments is number
          && request.resource.data.source in ['live', 'backfill_real', 'backfill_estimated'];
      }

      // Monthly plans V2 (doc id = YYYY-MM). Owner-only; same shape discipline
      // as budgetHistory. Deletes denied (write validation requires a payload).
      match /monthlyPlans/{month} {
        allow read: if owner(userId);
        allow write: if owner(userId)
          && month.matches('^[0-9]{4}-[0-9]{2}$')
          && request.resource.data.month == month
          && request.resource.data.version is int
          && request.resource.data.expectedIncome is number
          && request.resource.data.expectedIncome >= 0
          && request.resource.data.savingsTarget is number
          && request.resource.data.savingsTarget >= 0
          && request.resource.data.categoryBudgets is map
          && request.resource.data.plannedEvents is list
          && request.resource.data.plannedEvents.size() <= 100
          && request.resource.data.status in ['draft', 'confirmed']
          && request.resource.data.source in ['manual', 'copied_from_previous_month', 'from_recurring', 'auto'];
      }

      // Encouraging-insights pool consumed by the sendEncouragingInsight function.
      // Narrowly scoped to the single `encouraging` doc (no generic /derived/{doc}),
      // owner-only, with payload validation. NB: no hasOnly() — the function adds
      // lastSentTitle/lastSentAt to the same doc (Admin SDK), and a later client
      // merge would otherwise see those extra keys and be rejected.
      match /derived/encouraging {
        allow read: if owner(userId);
        allow write: if owner(userId)
          && request.resource.data.items is list
          && request.resource.data.items.size() <= 50;
      }

      // Derived monthly aggregates (versioned, regenerable, on-demand — the
      // original transactions stay the source of truth). Owner-only; deletes
      // denied like the other derived data.
      match /derived/monthlyAggregates {
        allow read: if owner(userId);
        allow create, update: if owner(userId)
          && request.resource.data.version is int
          && request.resource.data.months is list
          && request.resource.data.months.size() <= 600;
      }

      // Behavioural metric events (name+ts only — never financial data). The
      // owner can create allow-listed events and read their own; update/delete
      // are denied to clients (retention/purge runs via the Admin SDK).
      match /events/{eventId} {
        allow read:   if owner(userId);
        allow create: if owner(userId) && validEvent(request.resource.data);
      }
    }

    // User feedback: any signed-in user submits a document stamped with their own
    // uid; only the admin may read them back. Create-only (no updates/deletes).
    match /feedback/{fid} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly(['userId', 'userEmail', 'type', 'text', 'appVersion', 'createdAt', 'createdAtServer'])
        && request.resource.data.type in ['bug', 'idea', 'confusion', 'other']
        && (!('userEmail' in request.resource.data) || request.resource.data.userEmail == null || vStr(request.resource.data.userEmail, 320))
        && (!('text' in request.resource.data) || request.resource.data.text == null || vStr(request.resource.data.text, 5000))
        && vStr(request.resource.data.appVersion, 50);
      allow read: if isAdmin();
    }

    // Daily aggregated product metrics (DAU/WAU/MAU + engagement). Written
    // exclusively by the Admin SDK (rollup function); readable only by the
    // admin. Clients can never write.
    match /metrics/{day} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Expense-shortcut tokens (doc id = sha256 of the token). Managed exclusively
    // by Cloud Functions via the Admin SDK: NO client may ever read or write them.
    match /expenseTokens/{id} {
      allow read, write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
