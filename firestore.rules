rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can only read and write their own data.
    // The Admin SDK (Cloud Functions) bypasses these rules entirely.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /transactions/{txId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;

        // Create & update must keep the document well-formed: required fields
        // present and a positive numeric amount. Prevents writing malformed or
        // negative-amount records even with a valid session.
        allow create, update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.keys().hasAll(['date', 'description', 'amount', 'type', 'category', 'account'])
          && request.resource.data.amount is number
          && request.resource.data.amount > 0;
      }

      match /meta/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // User feedback: any signed-in user can submit a feedback document stamped
    // with their own uid; only the admin may read them back. No updates/deletes.
    match /feedback/{fid} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
        && request.auth.uid == 'qPtCOJGRrwOZ2EfjxMHwW6ZISXX2';
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
